<!-- Página de Inicio -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-graduation-cap"></i> Matriculación PAO-I-2026
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            <i class="fas fa-home"></i> Inicio
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/estudiantes">
                            <i class="fas fa-users"></i> Estudiantes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/matriculas">
                            <i class="fas fa-clipboard-list"></i> Matriculaciones
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">
                            <i class="fas fa-chart-bar"></i> Dashboard
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section bg-gradient-primary text-white py-5 mb-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h1 class="display-4 fw-bold mb-3">
                        <i class="fas fa-book"></i> Sistema de Matriculación de Estudiantes
                    </h1>
                    <p class="lead mb-4">
                        Gestión integral de matriculaciones para el período <strong>PAO-I-2026</strong>
                    </p>
                    <div class="btn-group" role="group">
                        <a href="/estudiantes/nuevo" class="btn btn-light btn-lg me-2">
                            <i class="fas fa-user-plus"></i> Nuevo Estudiante
                        </a>
                        <a href="/matriculas/nuevo" class="btn btn-light btn-lg">
                            <i class="fas fa-clipboard-check"></i> Nueva Matriculación
                        </a>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card bg-white text-dark shadow-lg">
                        <div class="card-body text-center">
                            <h3 class="card-title"><i class="fas fa-graduation-cap"></i></h3>
                            <h5 class="fw-bold">Periodo Académico</h5>
                            <p class="display-6 fw-bold text-primary mb-3">PAO-I-2026</p>
                            <p class="text-muted small">Período Académico Ordinario I - 2026</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Sección Principal -->
    <div class="container mb-5">
        <div class="row">
            <!-- Card Estudiantes -->
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="card-icon mb-3">
                            <i class="fas fa-users fa-3x text-primary"></i>
                        </div>
                        <h5 class="card-title fw-bold">Gestión de Estudiantes</h5>
                        <p class="card-text text-muted">
                            Administra el registro, actualización y consulta de datos de estudiantes.
                        </p>
                        <a href="/estudiantes" class="btn btn-primary">
                            <i class="fas fa-arrow-right"></i> Ver Estudiantes
                        </a>
                    </div>
                </div>
            </div>

            <!-- Card Matriculaciones -->
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="card-icon mb-3">
                            <i class="fas fa-clipboard-list fa-3x text-success"></i>
                        </div>
                        <h5 class="card-title fw-bold">Matriculaciones</h5>
                        <p class="card-text text-muted">
                            Realiza y gestiona las matriculaciones de estudiantes en carreras y modalidades.
                        </p>
                        <a href="/matriculas" class="btn btn-success">
                            <i class="fas fa-arrow-right"></i> Ver Matriculaciones
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Información sobre Carreras y Modalidades -->
        <div class="row mt-5">
            <div class="col-lg-6 mb-4">
                <h4 class="fw-bold mb-3">
                    <i class="fas fa-book-open text-primary"></i> Carreras Disponibles
                </h4>
                <div class="list-group">
                    <a href="#" class="list-group-item list-group-item-action">
                        <h6 class="mb-1"><i class="fas fa-code"></i> Desarrollo de Software</h6>
                        <p class="small text-muted mb-0">
                            Especialización en desarrollo de aplicaciones, software y sistemas informáticos.
                        </p>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action">
                        <h6 class="mb-1"><i class="fas fa-microchip"></i> Electrónica</h6>
                        <p class="small text-muted mb-0">
                            Formación en electrónica, sistemas embebidos y controladores.
                        </p>
                    </a>
                </div>
            </div>

            <div class="col-lg-6 mb-4">
                <h4 class="fw-bold mb-3">
                    <i class="fas fa-network-wired text-success"></i> Modalidades de Estudio
                </h4>
                <div class="list-group">
                    <a href="#" class="list-group-item list-group-item-action">
                        <h6 class="mb-1"><i class="fas fa-building"></i> Presencial</h6>
                        <p class="small text-muted mb-0">
                            Clases en el campus. Interacción directa con docentes y compañeros.
                        </p>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action">
                        <h6 class="mb-1"><i class="fas fa-laptop-house"></i> Virtual</h6>
                        <p class="small text-muted mb-0">
                            Clases en línea. Estudio flexible desde cualquier lugar.
                        </p>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-light mt-5 py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h6 class="fw-bold">Sistema de Matriculación</h6>
                    <p class="small mb-0">Período Académico: PAO-I-2026</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <h6 class="fw-bold">Información de Contacto</h6>
                    <small class="text-muted">
                        Para soporte, contacte al departamento de registro.
                    </small>
                </div>
            </div>
            <hr class="my-3">
            <p class="text-center small mb-0 text-muted">
                © 2026 - Sistema de Matriculación de Estudiantes - Todos los derechos reservados
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>

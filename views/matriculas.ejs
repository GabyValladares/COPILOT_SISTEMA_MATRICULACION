<!-- Vista: Listado de Matriculaciones -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-graduation-cap"></i> Matriculación PAO-I-2026
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home"></i> Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/estudiantes"><i class="fas fa-users"></i> Estudiantes</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/matriculas"><i class="fas fa-clipboard-list"></i> Matriculaciones</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Contenedor Principal -->
    <div class="container mt-4">
        <!-- Encabezado -->
        <div class="row mb-4">
            <div class="col-md-6">
                <h1 class="fw-bold">
                    <i class="fas fa-clipboard-list text-success"></i> Matriculaciones
                </h1>
            </div>
            <div class="col-md-6 text-md-end">
                <a href="/matriculas/nuevo" class="btn btn-success btn-lg">
                    <i class="fas fa-plus"></i> Nueva Matriculación
                </a>
            </div>
        </div>

        <!-- Estadísticas -->
        <% if (estadisticas && estadisticas.length > 0) { %>
            <div class="row mb-4">
                <% estadisticas.forEach(stat => { %>
                    <div class="col-md-6 col-lg-3 mb-3">
                        <div class="card text-center border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="card-title text-muted small">
                                    <%= stat.carrera %> - <%= stat.modalidad %>
                                </h6>
                                <h2 class="fw-bold text-primary"><%= stat.total %></h2>
                                <small class="text-muted">Estudiantes registrados</small>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>

        <!-- Tabla de Matriculaciones -->
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <% if (matriculas && matriculas.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-success">
                                <tr>
                                    <th>Estudiante</th>
                                    <th>Cédula</th>
                                    <th>Carrera</th>
                                    <th>Modalidad</th>
                                    <th>Fecha de Matricula</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% matriculas.forEach(mat => { %>
                                    <tr>
                                        <td>
                                            <strong><%= mat.nombre %> <%= mat.apellido %></strong>
                                        </td>
                                        <td><%= mat.cedula %></td>
                                        <td>
                                            <i class="fas fa-book"></i> <%= mat.carrera %>
                                        </td>
                                        <td>
                                            <% if (mat.modalidad === 'Presencial') { %>
                                                <i class="fas fa-building text-primary"></i> <%= mat.modalidad %>
                                            <% } else { %>
                                                <i class="fas fa-laptop-house text-info"></i> <%= mat.modalidad %>
                                            <% } %>
                                        </td>
                                        <td>
                                            <%= new Date(mat.fecha_matricula).toLocaleDateString('es-ES') %>
                                        </td>
                                        <td>
                                            <% if (mat.estado === 'activa') { %>
                                                <span class="badge bg-success">Activa</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary">Inactiva</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <a href="/matriculas/<%= mat.id %>/detalle" class="btn btn-sm btn-info" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="/matriculas/<%= mat.id %>/editar" class="btn btn-sm btn-warning" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-sm btn-danger" onclick="eliminarMatricula(<%= mat.id %>, '<%= mat.nombre %>')" title="Eliminar">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Información de registros -->
                    <div class="mt-3 text-muted small">
                        Total de matriculaciones: <strong><%= matriculas.length %></strong>
                    </div>
                <% } else { %>
                    <div class="alert alert-info text-center py-5">
                        <i class="fas fa-inbox fa-3x mb-3"></i>
                        <p class="mb-0">No hay matriculaciones registradas aún.</p>
                        <a href="/matriculas/nuevo" class="btn btn-success mt-3">
                            <i class="fas fa-plus"></i> Crear la primera matriculación
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-light mt-5 py-4">
        <div class="container">
            <p class="text-center small mb-0 text-muted">
                © 2026 - Sistema de Matriculación de Estudiantes - Período: <%= periodo %>
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script>
        function eliminarMatricula(id, nombre) {
            if (confirm(`¿Deseas eliminar la matriculación de ${nombre}?`)) {
                fetch(`/matriculas/${id}`, { method: 'DELETE' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            location.reload();
                        } else {
                            alert(data.message);
                        }
                    });
            }
        }
    </script>
</body>
</html>

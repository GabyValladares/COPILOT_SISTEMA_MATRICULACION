<!-- Vista: Dashboard / Estadísticas -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Sistema de Matriculación</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-graduation-cap"></i> Matriculación PAO-I-2026
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home"></i> Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/estudiantes"><i class="fas fa-users"></i> Estudiantes</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/matriculas"><i class="fas fa-clipboard-list"></i> Matriculaciones</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/dashboard"><i class="fas fa-chart-bar"></i> Dashboard</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Contenedor Principal -->
    <div class="container mt-4 mb-5">
        <!-- Encabezado -->
        <h1 class="fw-bold mb-4">
            <i class="fas fa-chart-bar text-success"></i> Dashboard de Matriculación
        </h1>

        <!-- Período Académico -->
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="fas fa-calendar"></i>
            <strong>Período Académico:</strong> PAO-I-2026 (Ordinario I - 2026)
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <!-- Tarjetas de Resumen -->
        <div class="row mb-5">
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card border-0 shadow-sm bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title mb-0 opacity-75">Total Estudiantes</h6>
                                <h2 class="fw-bold" id="total-estudiantes">0</h2>
                            </div>
                            <i class="fas fa-users fa-3x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card border-0 shadow-sm bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title mb-0 opacity-75">Matriculaciones Activas</h6>
                                <h2 class="fw-bold" id="total-matriculas">0</h2>
                            </div>
                            <i class="fas fa-clipboard-check fa-3x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card border-0 shadow-sm bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title mb-0 opacity-75">Período Académico</h6>
                                <h5 class="fw-bold">PAO-I-2026</h5>
                            </div>
                            <i class="fas fa-calendar-alt fa-3x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Estadísticas por Carrera y Modalidad -->
        <h4 class="fw-bold mb-3 mt-4">Distribución por Carrera y Modalidad</h4>
        <div class="row mb-5" id="estadisticas-container">
            <!-- Se cargará dinámicamente -->
            <div class="col-12">
                <div class="alert alert-warning">
                    <i class="fas fa-loading"></i> Cargando datos...
                </div>
            </div>
        </div>

        <!-- Información General -->
        <div class="row">
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-book"></i> Carreras</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1"><i class="fas fa-code text-primary"></i> Desarrollo de Software</h6>
                                    <small class="text-muted">Especialización en desarrollo de aplicaciones</small>
                                </div>
                                <span class="badge bg-primary rounded-pill" id="dev-count">0</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1"><i class="fas fa-microchip text-success"></i> Electrónica</h6>
                                    <small class="text-muted">Especialización en sistemas electrónicos</small>
                                </div>
                                <span class="badge bg-success rounded-pill" id="elec-count">0</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-network-wired"></i> Modalidades</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1"><i class="fas fa-building text-info"></i> Presencial</h6>
                                    <small class="text-muted">Clases en el campus</small>
                                </div>
                                <span class="badge bg-info rounded-pill" id="presencial-count">0</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1"><i class="fas fa-laptop-house text-warning"></i> Virtual</h6>
                                    <small class="text-muted">Clases en línea</small>
                                </div>
                                <span class="badge bg-warning rounded-pill" id="virtual-count">0</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Acciones Rápidas -->
        <div class="row mt-5">
            <div class="col-12">
                <h4 class="fw-bold mb-3">Acciones Rápidas</h4>
                <div class="btn-group" role="group">
                    <a href="/estudiantes/nuevo" class="btn btn-outline-primary btn-lg">
                        <i class="fas fa-user-plus"></i> Nuevo Estudiante
                    </a>
                    <a href="/matriculas/nuevo" class="btn btn-outline-success btn-lg">
                        <i class="fas fa-clipboard-check"></i> Nueva Matriculación
                    </a>
                    <a href="/estudiantes" class="btn btn-outline-info btn-lg">
                        <i class="fas fa-users"></i> Ver Estudiantes
                    </a>
                    <a href="/matriculas" class="btn btn-outline-warning btn-lg">
                        <i class="fas fa-list"></i> Ver Matriculaciones
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-light mt-5 py-4">
        <div class="container">
            <p class="text-center small mb-0 text-muted">
                © 2026 - Sistema de Matriculación de Estudiantes
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Cargar estadísticas
        document.addEventListener('DOMContentLoaded', async () => {
            try {
                const response = await fetch('/matriculas/api/estadisticas');
                const data = await response.json();

                if (data.success) {
                    const stats = data.data;
                    let html = '';
                    let totalMatriculas = 0;

                    stats.forEach(stat => {
                        let icon = stat.carrera.includes('Desarrollo') ? 'code' : 'microchip';
                        let modalIcon = stat.modalidad === 'Presencial' ? 'building' : 'laptop-house';
                        
                        html += `
                            <div class="col-md-6 col-lg-3 mb-3">
                                <div class="card text-center border-0 shadow-sm">
                                    <div class="card-body">
                                        <h6 class="card-title text-muted small">
                                            <i class="fas fa-${icon}"></i> ${stat.carrera}
                                        </h6>
                                        <h6 class="text-secondary">
                                            <i class="fas fa-${modalIcon}"></i> ${stat.modalidad}
                                        </h6>
                                        <h2 class="fw-bold text-primary">${stat.total}</h2>
                                        <small class="text-muted">Estudiantes</small>
                                    </div>
                                </div>
                            </div>
                        `;
                        totalMatriculas += stat.total;

                        // Contar por modalidad
                        if (stat.modalidad === 'Presencial') {
                            document.getElementById('presencial-count').textContent = stat.total;
                        } else if (stat.modalidad === 'Virtual') {
                            document.getElementById('virtual-count').textContent = stat.total;
                        }

                        // Contar por carrera
                        if (stat.carrera.includes('Desarrollo')) {
                            const currentDev = parseInt(document.getElementById('dev-count').textContent);
                            document.getElementById('dev-count').textContent = currentDev + stat.total;
                        } else {
                            const currentElec = parseInt(document.getElementById('elec-count').textContent);
                            document.getElementById('elec-count').textContent = currentElec + stat.total;
                        }
                    });

                    document.getElementById('estadisticas-container').innerHTML = html;
                    document.getElementById('total-matriculas').textContent = totalMatriculas;
                }
            } catch (error) {
                console.error('Error:', error);
            }

            // Cargar total de estudiantes
            try {
                const response = await fetch('/api/estudiantes/count');
                if (response.ok) {
                    const data = await response.json();
                    document.getElementById('total-estudiantes').textContent = data.count || 0;
                }
            } catch (error) {
                // El endpoint podría no existir
            }
        });
    </script>
</body>
</html>

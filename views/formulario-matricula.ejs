<!-- Vista: Formulario de Matriculación -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-graduation-cap"></i> Matriculación PAO-I-2026
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home"></i> Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/matriculas"><i class="fas fa-clipboard-list"></i> Matriculaciones</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Contenedor Principal -->
    <div class="container mt-4 mb-5">
        <!-- Encabezado -->
        <div class="row mb-4">
            <div class="col-md-8">
                <h1 class="fw-bold">
                    <i class="fas fa-<%= modo === 'crear' ? 'clipboard-check text-success' : 'edit text-warning' %>"></i>
                    <%= modo === 'crear' ? 'Nueva Matriculación' : 'Editar Matriculación' %>
                </h1>
            </div>
            <div class="col-md-4 text-md-end">
                <a href="/matriculas" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Volver
                </a>
            </div>
        </div>

        <!-- Formulario -->
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <form method="POST" action="<%= modo === 'crear' ? '/matriculas/crear' : `/matriculas/${matricula.id}/actualizar` %>">
                            <!-- Selección de Estudiante -->
                            <h5 class="fw-bold mb-3 text-primary">
                                <i class="fas fa-user"></i> Estudiante
                            </h5>

                            <div class="mb-3">
                                <label for="estudiante_id" class="form-label">Seleccionar Estudiante <span class="text-danger">*</span></label>
                                <select class="form-select form-select-lg" id="estudiante_id" name="estudiante_id" required>
                                    <option value="">-- Selecciona un estudiante --</option>
                                    <% estudiantes.forEach(est => { %>
                                        <option value="<%= est.id %>" 
                                            <%= matricula && matricula.estudiante_id === est.id ? 'selected' : '' %>>
                                            <%= est.nombre %> <%= est.apellido %> (Cédula: <%= est.cedula %>)
                                        </option>
                                    <% }); %>
                                </select>
                            </div>

                            <!-- Selección de Carrera -->
                            <h5 class="fw-bold mb-3 mt-4 text-primary">
                                <i class="fas fa-book"></i> Carrera Académica
                            </h5>

                            <div class="mb-3">
                                <label for="carrera_id" class="form-label">Carrera <span class="text-danger">*</span></label>
                                <div class="row">
                                    <% carreras.forEach(carrera => { %>
                                        <div class="col-md-6 mb-3">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" id="carrera_<%= carrera.id %>" 
                                                    name="carrera_id" value="<%= carrera.id %>"
                                                    <%= matricula && matricula.carrera_id === carrera.id ? 'checked' : '' %>
                                                    required>
                                                <label class="form-check-label" for="carrera_<%= carrera.id %>">
                                                    <strong><%= carrera.nombre %></strong>
                                                    <br>
                                                    <small class="text-muted"><%= carrera.codigo %></small>
                                                </label>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>

                            <!-- Selección de Modalidad -->
                            <h5 class="fw-bold mb-3 mt-4 text-primary">
                                <i class="fas fa-network-wired"></i> Modalidad de Estudio
                            </h5>

                            <div class="mb-3">
                                <label for="modalidad_id" class="form-label">Modalidad <span class="text-danger">*</span></label>
                                <div class="row">
                                    <% modalidades.forEach(modalidad => { %>
                                        <div class="col-md-6 mb-3">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" id="modalidad_<%= modalidad.id %>" 
                                                    name="modalidad_id" value="<%= modalidad.id %>"
                                                    <%= matricula && matricula.modalidad_id === modalidad.id ? 'checked' : '' %>
                                                    required>
                                                <label class="form-check-label" for="modalidad_<%= modalidad.id %>">
                                                    <strong><%= modalidad.nombre %></strong>
                                                    <br>
                                                    <small class="text-muted"><%= modalidad.descripcion %></small>
                                                </label>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>

                            <!-- Estado (solo para edición) -->
                            <% if (modo === 'editar') { %>
                                <h5 class="fw-bold mb-3 mt-4 text-primary">Estado</h5>
                                <div class="mb-3">
                                    <label for="estado" class="form-label">Estado de la Matriculación</label>
                                    <select class="form-select" id="estado" name="estado">
                                        <option value="activa" <%= matricula && matricula.estado === 'activa' ? 'selected' : '' %>>Activa</option>
                                        <option value="inactiva" <%= matricula && matricula.estado === 'inactiva' ? 'selected' : '' %>>Inactiva</option>
                                    </select>
                                </div>
                            <% } %>

                            <!-- Botones -->
                            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4 pt-3 border-top">
                                <a href="/matriculas" class="btn btn-secondary btn-lg">Cancelar</a>
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="fas fa-save"></i>
                                    <%= modo === 'crear' ? 'Crear Matriculación' : 'Actualizar Matriculación' %>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Panel de Información -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0"><i class="fas fa-lightbulb"></i> Información Importante</h6>
                    </div>
                    <div class="card-body">
                        <h6 class="fw-bold mb-2">Requerimientos:</h6>
                        <ul class="small">
                            <li>✓ Seleccionar un estudiante activo</li>
                            <li>✓ Elegir una carrera</li>
                            <li>✓ Definir la modalidad de estudio</li>
                        </ul>

                        <h6 class="fw-bold mb-2 mt-3">Carreras Disponibles:</h6>
                        <ul class="small">
                            <li><i class="fas fa-code"></i> Desarrollo de Software</li>
                            <li><i class="fas fa-microchip"></i> Electrónica</li>
                        </ul>

                        <h6 class="fw-bold mb-2 mt-3">Modalidades:</h6>
                        <ul class="small">
                            <li><i class="fas fa-building"></i> Presencial - Clases en campus</li>
                            <li><i class="fas fa-laptop-house"></i> Virtual - Clases en línea</li>
                        </ul>
                    </div>
                </div>

                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0"><i class="fas fa-calendar"></i> Período Académico</h6>
                    </div>
                    <div class="card-body">
                        <h5 class="fw-bold text-primary">PAO-I-2026</h5>
                        <small class="text-muted">Período Académico Ordinario I - 2026</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-light mt-5 py-4">
        <div class="container">
            <p class="text-center small mb-0 text-muted">
                © 2026 - Sistema de Matriculación de Estudiantes
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

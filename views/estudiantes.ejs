<!-- Vista: Listado de Estudiantes -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-graduation-cap"></i> Matriculación PAO-I-2026
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home"></i> Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/estudiantes"><i class="fas fa-users"></i> Estudiantes</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/matriculas"><i class="fas fa-clipboard-list"></i> Matriculaciones</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard"><i class="fas fa-chart-bar"></i> Dashboard</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Contenedor Principal -->
    <div class="container mt-4">
        <!-- Encabezado -->
        <div class="row mb-4">
            <div class="col-md-6">
                <h1 class="fw-bold">
                    <i class="fas fa-users text-primary"></i> Estudiantes
                </h1>
            </div>
            <div class="col-md-6 text-md-end">
                <a href="/estudiantes/nuevo" class="btn btn-primary btn-lg">
                    <i class="fas fa-user-plus"></i> Nuevo Estudiante
                </a>
            </div>
        </div>

        <!-- Alertas de éxito/error -->
        <% if (typeof message !== 'undefined') { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle"></i> <%= message %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <!-- Tabla de Estudiantes -->
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <% if (estudiantes && estudiantes.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-primary">
                                <tr>
                                    <th>Cédula</th>
                                    <th>Nombre</th>
                                    <th>Email</th>
                                    <th>Teléfono</th>
                                    <th>Ciudad</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% estudiantes.forEach(est => { %>
                                    <tr>
                                        <td><strong><%= est.cedula %></strong></td>
                                        <td>
                                            <%= est.nombre %> <%= est.apellido %>
                                        </td>
                                        <td>
                                            <a href="mailto:<%= est.email %>"><%= est.email %></a>
                                        </td>
                                        <td><%= est.telefono || '-' %></td>
                                        <td><%= est.ciudad || '-' %></td>
                                        <td>
                                            <% if (est.estado === 'activo') { %>
                                                <span class="badge bg-success">Activo</span>
                                            <% } else { %>
                                                <span class="badge bg-danger">Inactivo</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <a href="/estudiantes/<%= est.id %>/detalle" class="btn btn-sm btn-info" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="/estudiantes/<%= est.id %>/editar" class="btn btn-sm btn-warning" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-sm btn-danger" onclick="eliminarEstudiante(<%= est.id %>, '<%= est.nombre %>')" title="Eliminar">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Información de registros -->
                    <div class="mt-3 text-muted small">
                        Total de estudiantes: <strong><%= estudiantes.length %></strong>
                    </div>
                <% } else { %>
                    <div class="alert alert-info text-center py-5">
                        <i class="fas fa-inbox fa-3x mb-3"></i>
                        <p class="mb-0">No hay estudiantes registrados aún.</p>
                        <a href="/estudiantes/nuevo" class="btn btn-primary mt-3">Registrar el primer estudiante</a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-light mt-5 py-4">
        <div class="container">
            <p class="text-center small mb-0 text-muted">
                © 2026 - Sistema de Matriculación de Estudiantes
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script>
        function eliminarEstudiante(id, nombre) {
            if (confirm(`¿Deseas eliminar a ${nombre}?`)) {
                fetch(`/estudiantes/${id}`, { method: 'DELETE' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            location.reload();
                        } else {
                            alert(data.message);
                        }
                    });
            }
        }
    </script>
</body>
</html>
